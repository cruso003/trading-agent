# GoldTrader AI Agent — Environment Variables
# Copy to .env and fill in real values
# Never commit .env to version control

# AI APIs
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=TELEGRAM_CHAT_ID=6808720x2xx

# MT5 Demo
MT5_DEMO_LOGIN=
MT5_DEMO_PASSWORD=
MT5_DEMO_SERVER=

# MT5 Live
MT5_LIVE_LOGIN=
MT5_LIVE_PASSWORD=
MT5_LIVE_SERVER=

# Active Account (demo or live — never both)
ACTIVE_ACCOUNT=demo

# Symbol (check Market Watch in MT5 for exact name)
# Exness uses XAUUSDm, other brokers may use XAUUSD or GOLD
SYMBOL=XAUUSDm
MAGIC_NUMBER=234001

# Risk Parameters
MAX_DAILY_LOSS_USD=50
MAX_POSITIONS=2
MAX_RISK_PER_TRADE=0.02
SL_MIN_POINTS=8
SL_MAX_POINTS=50
MIN_RR_RATIO=1.5
POST_TRADE_COOLING_MINUTES=20
POST_LOSS_COOLING_MINUTES=30

# Trading Windows (GMT+0)
WINDOW_1_START=23:00
WINDOW_1_END=01:00
WINDOW_2_START=12:00
WINDOW_2_END=14:00

# Models
CLAUDE_MODEL=claude-sonnet-4-6
GPT_MODEL=gpt-4o

# Runtime
LOG_LEVEL=INFO
DB_PATH=agent/data/agent.db
NEWS_CACHE_MINUTES=15
